@using Clayzor.Lib.DALC
@inject DbManager Db
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<ClayEditForm TEntity="MedicalTest"
               Model="Model"
               Title="@(Model.Id == 0 ? "Новое исследование" : $"Исследование #{Model.Id}")"
               Icon="@Icons.Material.Filled.Science"
               OnSave="HandleSave"
               OnDelete="HandleDelete"
               ShowDelete="@(Model.Id != 0)">

    <div class="clay-form-dense">

    <MudTextField @bind-Value="Model.Name"
                  Label="Название"
                  Required="true"
                  RequiredError="Название обязательно"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-2" />

    <ClayComboBox TItem="MedicalTestType"
                   @bind-Value="Model.TestTypeId"
                   Items="_testTypes"
                   Label="Тип исследования"
                   Required="true"
                   Class="mb-2" />

    <MudNumericField @bind-Value="Model.Order"
                     Label="Порядок"
                     Variant="Variant.Outlined"
                     Margin="Margin.Dense"
                     Class="mb-2" />

    <MudText Typo="Typo.subtitle2" Class="mt-1 mb-1">Нормы для женщин</MudText>
    <MudGrid Spacing="2">
        <MudItem xs="6">
            <MudNumericField @bind-Value="Model.NormMinFemale"
                             Label="От"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Class="mb-2" />
        </MudItem>
        <MudItem xs="6">
            <MudNumericField @bind-Value="Model.NormMaxFemale"
                             Label="По"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Class="mb-2" />
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.subtitle2" Class="mt-1 mb-1">Нормы для мужчин</MudText>
    <MudGrid Spacing="2">
        <MudItem xs="6">
            <MudNumericField @bind-Value="Model.NormMinMale"
                             Label="От"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Class="mb-2" />
        </MudItem>
        <MudItem xs="6">
            <MudNumericField @bind-Value="Model.NormMaxMale"
                             Label="По"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Class="mb-2" />
        </MudItem>
    </MudGrid>

    <MudTextField @bind-Value="Model.NormString"
                  Label="Норма (строка)"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-2" />

    <div class="d-flex flex-wrap gap-4">
        <MudSwitch @bind-Value="Model.IsGroup"
                   Label="Группа"
                   Color="Color.Primary" />

        <MudSwitch @bind-Value="Model.IsConclusion"
                   Label="Заключение"
                   Color="Color.Primary" />
    </div>

    </div>
</ClayEditForm>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public MedicalTest Model { get; set; } = new();

    private List<MedicalTestType> _testTypes = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _testTypes = await MedicalTestType.GetAllAsync(Db);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка загрузки типов: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleSave(MedicalTest entity)
    {
        try
        {
            if (entity.Id == 0)
                await entity.InsertAsync(Db);
            else
                await entity.UpdateAsync(Db);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка сохранения: {ex.Message}", Severity.Error);
            return;
        }

        MudDialog?.Close(DialogResult.Ok(entity));
    }

    private async Task HandleDelete(MedicalTest entity)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, "Подтверждение удаления" },
            { x => x.Message, $"Удалить исследование «{entity.Name}»?" },
            { x => x.ConfirmText, "Удалить" },
            { x => x.CancelText, "Отмена" }
        };
        var options = new DialogOptionsEx { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, DragMode = MudDialogDragMode.Simple };
        var dialog = await DialogService.ShowExAsync<ConfirmDialog>("Подтверждение", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled)
            return;

        try
        {
            await entity.DeleteAsync(Db);
            Snackbar.Add("Запись удалена", Severity.Success);
            MudDialog?.Cancel();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка удаления: {ex.Message}", Severity.Error);
        }
    }
}
